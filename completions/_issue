#compdef issue

_issue() {
  local -a commands
  commands=(
    'new:Create a new issue directory with issue.yaml metadata'
    'init:Initialize issue.yaml metadata in current directory'
    'read:Read a property value from issue.yaml'
    'pick:Pick an issue workspace and print its path'
  )

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-V --version)'{-V,--version}'[Show version]' \
    '1:command:->command' \
    '*::args:->args'

  case $state in
    command)
      _describe 'command' commands
      ;;
    args)
      case $words[2] in
        new|init)
          _arguments '1:issue-id:'
          ;;
        pick)
          _arguments '1:base-path:_files -/'
          ;;
        read)
          _arguments '1:prop:(id branch title root)'
          ;;
        *)
          _arguments
          ;;
      esac
      ;;
  esac
}

_issue "$@"
